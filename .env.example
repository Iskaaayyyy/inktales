PORT=3000
SESSION_SECRET=replace-this-with-a-long-random-secret
NODE_ENV=development

# Gemini parses stories into accurate panel JSON.
# Put your real key only in .env, never inside GitHub or frontend files.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Pollinations generates the actual manga/comic/animated keyframe images.
# Token is optional for testing, but recommended for better limits.
POLLINATIONS_TOKEN=
POLLINATIONS_REFERRER=localhost
POLLINATIONS_IMAGE_MODEL=flux
# url = fastest/recommended; download = saves generated images to public/generated but may be slower
POLLINATIONS_DELIVERY_MODE=url

# AI conversion controls
ENABLE_AI_IMAGES=true
AI_MAX_PANELS=8
AI_MAX_PAGES=3
AI_TIMEOUT_MS=60000

# Optional: add deployed frontend origins if frontend and backend are hosted separately.
CLIENT_ORIGIN=
